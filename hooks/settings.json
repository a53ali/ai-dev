{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/secrets-scanner.sh",
            "statusMessage": "Scanning for secrets...",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-destructive.sh",
            "statusMessage": "Checking command safety...",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/conventional-commit.sh",
            "statusMessage": "Validating commit message...",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/lint-on-write.sh",
            "statusMessage": "Linting...",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/test-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
